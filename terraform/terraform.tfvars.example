# ──────────────────────────────────────────────
# General
# ──────────────────────────────────────────────
aws_region   = "us-east-1"
project_name = "rag-system"
environment  = "production"

# ──────────────────────────────────────────────
# GitHub OIDC
# ──────────────────────────────────────────────
github_org  = "your-github-username"
github_repo = "rag-system"

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
db_name     = "ragdb"
db_username = "raguser"
db_password = "CHANGE_ME_use_a_strong_password"

# ──────────────────────────────────────────────
# Application Secrets
# ──────────────────────────────────────────────
openai_api_key   = "sk-..."
pinecone_api_key = "your-pinecone-key"
pinecone_index   = "rag-index"
jwt_secret_key   = "CHANGE_ME_use_a_random_string"

# ──────────────────────────────────────────────
# Domain (optional — leave empty if not using)
# ──────────────────────────────────────────────
# domain_name = "rag.yourdomain.com"
